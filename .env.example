# 复制为 .env 并填入真实值（.env 已加入 .gitignore，绝不提交到版本库）

# ── 观远 BI 登录凭证 ─────────────────────────────────────────────────────────
GY_BASE_URL=https://your-bi-domain.com
GY_ACCOUNT=你的工号
GY_PASSWORD=你的密码
# 仪表板完整 URL（screenshot_dashboard.py / validate.py 使用）
GY_DASHBOARD_URL=https://your-bi-domain.com/home/web-app/YOUR_PAGE_ID

# Playwright 登录后自动填入，通常无需手动设置
GY_COOKIES=

# ── AI Provider 选择 ──────────────────────────────────────────────────────────
# 可选值：gemini（默认） / claude / azure / openai
AI_PROVIDER=gemini

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=你的Gemini_API_Key
GEMINI_MODEL=gemini-2.5-pro

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=你的Anthropic_API_Key
# CLAUDE_MODEL=claude-opus-4-6

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=你的Azure_OpenAI_Key
AZURE_OPENAI_ENDPOINT=https://你的资源名.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=你的部署名
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── OpenAI 官方 ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=你的OpenAI_API_Key
# OPENAI_MODEL=gpt-4o

# ── 飞书机器人 ────────────────────────────────────────────────────────────────
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的Webhook_ID
